# Indodax API credentials (both required for live trading)
INDODAX_KEY=your_api_key_here
INDODAX_SECRET=your_api_secret_here

# Risk and sizing
# Order size is computed dynamically: RISK_PER_TRADE * INITIAL_CAPITAL / coin_price
RISK_PER_TRADE=0.01
INITIAL_CAPITAL=1000000
TARGET_PROFIT_PCT=0.2
MAX_LOSS_PCT=0.1
MAX_SLIPPAGE_PCT=0.001
# Trailing stop: price trails peak by this fraction (0 = disabled)
TRAILING_STOP_PCT=0.0

# Strategy parameters
REALTIME_MODE=false
# When REALTIME_MODE=true, INTERVAL_SECONDS defaults to 1s unless overridden below
INTERVAL_SECONDS=300
FAST_WINDOW=12
SLOW_WINDOW=48
MIN_CONFIDENCE=0.52
GRID_ENABLED=false
GRID_LEVELS_PER_SIDE=3
GRID_SPACING_PCT=0.004
# Optional: override per-level amount (defaults to RISK_PER_TRADE * INITIAL_CAPITAL / price when unset)
# GRID_ORDER_SIZE=0.0002

# Order queue / rate limit
ORDER_QUEUE_ENABLED=true
ORDER_MIN_INTERVAL=0.25
# Delay (seconds) between per-pair API requests during pair scanning (prevents HTTP 429)
SCAN_REQUEST_DELAY=0.2
# Recent trade ticks fetched per pair when building candles from /api/trades (fallback to OHLC)
TRADE_COUNT=1000
# Minimum candle count required for reliable RSI/MACD/BB indicators (pairs below are skipped in scan)
MIN_CANDLES=20

# Realtime streaming (WebSocket preferred, REST fallback)
WEBSOCKET_ENABLED=true
# Official Indodax market-data WebSocket (Centrifuge protocol)
WEBSOCKET_URL=wss://ws3.indodax.com/ws/
# Seconds without a WS ticker update before the feed is considered stale and REST fallback activates
WS_STALE_THRESHOLD=120

# Multi-pair scan optimisation
# Rotate N pairs per cycle (0 = scan all); reduces per-cycle REST load
PAIRS_PER_CYCLE=50
# Minimum 24-h IDR trading volume a pair must have to be analysed (0 = no filter)
MIN_VOLUME_IDR=0

# Execution mode
DRY_RUN=true
STAGED_ENTRY_STEPS=3
RUN_ONCE=false

# Autonomous 24/7 operation
# Interval (seconds) used when monitoring an open position between exit checks
POSITION_CHECK_INTERVAL=60
# Print a full performance summary every N completed scan cycles (0 disables)
CYCLE_SUMMARY_INTERVAL=10
# Trading mode: "continuous" = run 24/7 rotating pairs; "single" = one buy→sell cycle then stop
TRADE_MODE=continuous

# Logging
# Optional path to a log file.  When set, all log lines are written to BOTH
# the terminal and this file simultaneously (append mode).
# LOG_FILE=/var/log/indodax-bot/bot.log

# Telegram notifications (optional — both token AND chat_id must be set)
# Create a bot via @BotFather and get your chat ID from @userinfobot
# TELEGRAM_TOKEN=123456789:ABCDEFGhijklmnopqrstuvwxyz
# TELEGRAM_CHAT_ID=987654321

# Discord webhook notifications (optional)
# Create an Incoming Webhook in Discord Server Settings → Integrations
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Auto-resume state persistence
STATE_PATH=bot_state.json
STATE_BACKUP_INTERVAL=10

# Multi-timeframe analysis (optional — filters noise by requiring alignment across timeframes)
# Comma-separated list of Indodax OHLC timeframes to fetch per pair in addition to the primary.
# Valid values: 1, 15, 30, 60, 240, 1D.  Leave empty to disable (default).
# MTF_TIMEFRAMES=1,15,60

# Risk exposure caps (0 = disabled)
# MAX_EXPOSURE_PER_COIN_PCT=0.3    # max 30% of equity in one coin at a time
# MAX_DAILY_LOSS_PCT=0.05          # stop trading buys when daily loss exceeds 5% of day-open equity

# Dynamic pair selection — auto-refreshes the watchlist with the top-N most liquid pairs
# 0 = disabled (use the initial static pair list from get_pairs() indefinitely)
DYNAMIC_PAIRS_REFRESH_CYCLES=0
DYNAMIC_PAIRS_TOP_N=50

# Partial take-profit — sell a fraction of the position when price hits TP, let the rest run
# 0 = sell all (disabled by default).  E.g. 0.5 = sell 50% at TP, keep 50%.
# PARTIAL_TP_FRACTION=0.5

# Re-entry logic — prevent immediate re-buys after a sell
# RE_ENTRY_COOLDOWN_SECONDS=300    # wait at least 5 minutes after selling
# RE_ENTRY_DIP_PCT=0.02            # price must dip 2% below last sell price before re-entering

# Adaptive scan interval — reduce sleep time during high-volatility periods
ADAPTIVE_INTERVAL_ENABLED=false
ADAPTIVE_INTERVAL_MIN_SECONDS=30  # minimum sleep between scans when volatile

# Portfolio-wide risk cap (0 = disabled)
# MAX_PORTFOLIO_RISK_PCT=0.5    # max 50% of equity tied up in open positions

# Minimum order-book depth (IDR) — skip thin markets
# MIN_LIQUIDITY_DEPTH_IDR=50000000  # require at least 50M IDR of bid+ask depth

# ── Capital management: principal / profit-buffer compounding ─────────────────
# The bot separates capital into:
#   principal      = INITIAL_CAPITAL (fixed anchor, never eroded)
#   profit_buffer  = accumulated realised profits (compounds into next trades)
#   effective_cap  = principal + profit_buffer (grows as you win)

# Stop new buys when profit buffer drops X% from its all-time peak
# 0 = disabled (default)
# PROFIT_BUFFER_DRAWDOWN_PCT=0.3   # block buys if profits fall 30% from peak

# ── Dynamic take-profit / let profits run ─────────────────────────────────────
# Instead of always closing at TARGET_PROFIT_PCT, the bot can keep the position
# open and trail a floor below the running peak — capturing more upside while
# locking in profits.

# Trailing take-profit: trail this % below the highest price since TP was hit
# 0 = disabled — close exactly at TARGET_PROFIT_PCT (default)
# TRAILING_TP_PCT=0.01   # trail 1% below peak price

# Conditional TP: market-condition checks before allowing the TP exit.
# Hold past TP while trend strength is above this threshold (0 = disabled)
# CONDITIONAL_TP_MIN_TREND_STRENGTH=0.4

# Hold past TP while order-book buy-pressure imbalance >= this (0 = disabled)
# Positive = more bids than asks; e.g. 0.1 = at least 10% bid dominance
# CONDITIONAL_TP_MIN_OB_IMBALANCE=0.1

# Close when RSI exceeds this level — overbought / take profit (0 = disabled)
# CONDITIONAL_TP_MAX_RSI=70

# ── Orderbook wall / sell-wall guard ─────────────────────────────────────────
# Skip buy when total ask-side depth (top-20 levels) is this many times larger
# than total bid-side depth.  Prevents entering against a heavy sell wall.
# 0 = disabled (default).  E.g. 5 = skip buy if asks ≥ 5× bids.
# ORDERBOOK_WALL_THRESHOLD=5

# ── Pump protection (FOMO guard) ──────────────────────────────────────────────
# Skip entry when the price has risen by more than PUMP_PROTECTION_PCT within
# the last PUMP_LOOKBACK_SECONDS.  Prevents chasing a pump that is likely to
# retrace.  0 = disabled (default).
# PUMP_PROTECTION_PCT=0.05     # skip buy if price rose >5% in the lookback window
# PUMP_LOOKBACK_SECONDS=60     # rolling window in seconds (default 60s)

# ── Spread filter ─────────────────────────────────────────────────────────────
# Skip any trade (buy or sell) when the live bid-ask spread exceeds this
# fraction of the best bid price.  Wide spreads inflate execution cost.
# 0 = disabled (default).  E.g. 0.002 = skip when spread > 0.2%.
# MAX_SPREAD_PCT=0.002
