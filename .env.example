# Indodax API key (required for live trading)
INDODAX_KEY=your_api_key_here

# Trading pairs: fallback pair and optional comma-separated scan list
TRADE_PAIR=btc_idr
TRADE_PAIRS=btc_idr,eth_idr

# Risk and sizing
BASE_ORDER_SIZE=0.0001
RISK_PER_TRADE=0.01
INITIAL_CAPITAL=1000000
TARGET_PROFIT_PCT=0.2
MAX_LOSS_PCT=0.1
MAX_SLIPPAGE_PCT=0.001

# Strategy parameters
INTERVAL_SECONDS=300
FAST_WINDOW=12
SLOW_WINDOW=48
MIN_CONFIDENCE=0.52

# Execution mode
DRY_RUN=true
AUTO_RESUME=true
STATE_FILE=bot_state.json
STAGED_ENTRY_STEPS=3
RUN_ONCE=false
