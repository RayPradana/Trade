# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Indodax Trading Bot — Full-Featured Configuration                       ║
# ║                                                                          ║
# ║  CAPITAL MODE QUICK-START GUIDE                                          ║
# ║  ─────────────────────────────                                           ║
# ║  Small capital   (< 2 M IDR)   — ADAPTIVE SIZING: Tier 0                ║
# ║    • INITIAL_CAPITAL=1000000   RISK_PER_TRADE=0.10                       ║
# ║    • MULTI_POSITION_MAX=2      MAX_OPEN_POSITIONS=2                      ║
# ║    • MIN_ORDER_IDR=100000      STAGED_ENTRY_STEPS=1                      ║
# ║    • TARGET_PROFIT_PCT=0.015   TRAILING_STOP_PCT=0.025                   ║
# ║                                                                          ║
# ║  Medium capital  (2 M – 10 M IDR)  — ADAPTIVE SIZING: Tier 1           ║
# ║    • INITIAL_CAPITAL=5000000   RISK_PER_TRADE=0.07                       ║
# ║    • MULTI_POSITION_MAX=3      MAX_OPEN_POSITIONS=3                      ║
# ║    • MIN_ORDER_IDR=100000      STAGED_ENTRY_STEPS=2                      ║
# ║    • TARGET_PROFIT_PCT=0.02    TRAILING_STOP_PCT=0.03                    ║
# ║                                                                          ║
# ║  Large capital   (> 10 M IDR)  — ADAPTIVE SIZING: Tier 2                ║
# ║    • INITIAL_CAPITAL=20000000  RISK_PER_TRADE=0.03                       ║
# ║    • MULTI_POSITION_MAX=5      MAX_OPEN_POSITIONS=5                      ║
# ║    • MIN_ORDER_IDR=100000      STAGED_ENTRY_STEPS=3                      ║
# ║    • TARGET_PROFIT_PCT=0.025   TRAILING_STOP_PCT=0.035                   ║
# ║                                                                          ║
# ║  When ADAPTIVE_SIZING_ENABLED=true the bot automatically picks the       ║
# ║  right tier based on your current equity — you only need to set          ║
# ║  INITIAL_CAPITAL correctly and the rest scales automatically.            ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Indodax API credentials (both required for live trading) ─────────────────
INDODAX_KEY=your_api_key_here
INDODAX_SECRET=your_api_secret_here

# ── Capital and risk ──────────────────────────────────────────────────────────
# Set INITIAL_CAPITAL to your actual balance.  All position sizes derive from it.
INITIAL_CAPITAL=1000000
RISK_PER_TRADE=0.10
TARGET_PROFIT_PCT=0.02
MAX_LOSS_PCT=0.10
MAX_SLIPPAGE_PCT=0.001
# Cross the spread slightly for faster fills (still bounded by MAX_SLIPPAGE_PCT)
ENTRY_AGGRESSIVENESS_PCT=0.0005
# Aggressiveness applied when re-attempting an unfilled pending buy
ENTRY_RETRY_AGGRESSIVENESS_PCT=0.001
# Max limit-order price-chase attempts before falling back to market (0 = unlimited)
CHASE_MAX_RETRIES=5
# Minimum entry quality score (0–1) — aggregates regime, trend, OB, volume, micro-trend
ENTRY_QUALITY_MIN_SCORE=0.25
# Seconds to wait between resume-buy cycles
RESUME_BUY_WAIT_SECONDS=20
# Trailing stop: price trails peak by this fraction (anchored at buy fill price)
TRAILING_STOP_PCT=0.03

# ── Strategy parameters ───────────────────────────────────────────────────────
REALTIME_MODE=false
INTERVAL_SECONDS=300
FAST_WINDOW=12
SLOW_WINDOW=48
MIN_CONFIDENCE=0.52
GRID_ENABLED=false
GRID_LEVELS_PER_SIDE=3
GRID_SPACING_PCT=0.004
# GRID_ORDER_SIZE=0.0002

# ── Trade entry filters ───────────────────────────────────────────────────────
# Skip BUY when RSI ≥ this (overbought guard; 0 = disabled)
BUY_MAX_RSI=85
# Skip BUY when price is within this fraction of nearest resistance level
BUY_MAX_RESISTANCE_PROXIMITY_PCT=0.01
# Cooldown after each trade on the same pair (seconds; 0 = disabled)
PAIR_COOLDOWN_SECONDS=300

# ── Order queue / rate limit ──────────────────────────────────────────────────
ORDER_QUEUE_ENABLED=true
ORDER_MIN_INTERVAL=2.0
SCAN_REQUEST_DELAY=0.2

# ── API caching ───────────────────────────────────────────────────────────────
ACCOUNT_INFO_CACHE_TTL=30
OPEN_ORDERS_CACHE_TTL=15
TRADE_COUNT=1000
MIN_CANDLES=20
SCAN_CANDLE_CACHE_SECONDS=60

# ── Realtime streaming ────────────────────────────────────────────────────────
WEBSOCKET_ENABLED=true
WEBSOCKET_URL=wss://ws3.indodax.com/ws/
WS_STALE_THRESHOLD=120
WEBSOCKET_BATCH_SIZE=100

# ── Multi-pair scan ───────────────────────────────────────────────────────────
PAIRS_PER_CYCLE=20
# Minimum 24-h IDR volume — reject low-liquidity pairs early
MIN_VOLUME_IDR=500000000
# Minimum total order-book IDR volume at entry (0 = disabled)
MIN_ORDERBOOK_VOLUME_IDR=0
# Skip coins below this IDR price (koin sepi guard)
MIN_COIN_PRICE_IDR=50

# ── Execution mode ────────────────────────────────────────────────────────────
DRY_RUN=true
# Staged entry tranches — collapses to 1 step when cash < STAGED_ENTRY_MIN_EQUITY
STAGED_ENTRY_STEPS=3
STAGED_ENTRY_MIN_EQUITY=1000000
RUN_ONCE=false

# ── Autonomous 24/7 operation ─────────────────────────────────────────────────
POSITION_CHECK_INTERVAL=60
CYCLE_SUMMARY_INTERVAL=10
TRADE_MODE=continuous

# ── Multi-position / parallel trading ────────────────────────────────────────
MULTI_POSITION_ENABLED=true
MULTI_POSITION_MAX=3
MAX_OPEN_POSITIONS=3

# ── Logging and journal ───────────────────────────────────────────────────────
# LOG_FILE=/var/log/indodax-bot/bot.log
# JOURNAL_PATH=trade_journal.csv

# ── Telegram / Discord notifications ─────────────────────────────────────────
# TELEGRAM_TOKEN=123456789:ABCDEFGhijklmnopqrstuvwxyz
# TELEGRAM_CHAT_ID=987654321
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Auto-resume state persistence ────────────────────────────────────────────
STATE_PATH=bot_state.json
STATE_BACKUP_INTERVAL=10

# ── Multi-timeframe analysis ──────────────────────────────────────────────────
MTF_TIMEFRAMES=1,15,60

# ── Risk exposure caps ────────────────────────────────────────────────────────
MAX_EXPOSURE_PER_COIN_PCT=0.30
MAX_DAILY_LOSS_PCT=0.05

# ── Dynamic pair selection ────────────────────────────────────────────────────
DYNAMIC_PAIRS_REFRESH_CYCLES=10
DYNAMIC_PAIRS_TOP_N=50
TOP_VOLUME_MIN_VOLUME_IDR=100000000
TOP_VOLUME_MIN_PRICE_CHANGE_24H_PCT=0.005

# ── Partial take-profit ───────────────────────────────────────────────────────
# Sell a fraction at TP and let the rest ride the trailing TP
PARTIAL_TP_FRACTION=0.5

# ── Multi-level partial take-profit ───────────────────────────────────────────
PARTIAL_TP2_FRACTION=0.3
PARTIAL_TP2_TARGET_PCT=0.08
PARTIAL_TP3_FRACTION=0.2
PARTIAL_TP3_TARGET_PCT=0.12

# ── Re-entry logic ────────────────────────────────────────────────────────────
RE_ENTRY_COOLDOWN_SECONDS=300
RE_ENTRY_DIP_PCT=0.02

# ── Adaptive scan interval ────────────────────────────────────────────────────
ADAPTIVE_INTERVAL_ENABLED=true
ADAPTIVE_INTERVAL_MIN_SECONDS=30

# ── Portfolio-wide risk cap ───────────────────────────────────────────────────
MAX_PORTFOLIO_RISK_PCT=0.50

# ── Minimum order-book depth ──────────────────────────────────────────────────
MIN_LIQUIDITY_DEPTH_IDR=100000

# ── Capital management ────────────────────────────────────────────────────────
PROFIT_BUFFER_DRAWDOWN_PCT=0.30

# ── Dynamic take-profit / trailing TP ────────────────────────────────────────
TRAILING_TP_PCT=0.02
# Hold past TP while trend strength is above this threshold
CONDITIONAL_TP_MIN_TREND_STRENGTH=0.40
# Hold past TP while OB buy-pressure imbalance ≥ this
CONDITIONAL_TP_MIN_OB_IMBALANCE=0.10
# Close when RSI exceeds this level (overbought TP trigger)
CONDITIONAL_TP_MAX_RSI=70

# ── Orderbook wall / sell-wall guard ─────────────────────────────────────────
# Skip buy when ask-side depth ≥ N × bid-side depth
ORDERBOOK_WALL_THRESHOLD=5

# ── Orderbook imbalance entry guard ──────────────────────────────────────────
# Skip BUY when seller dominance exceeds this threshold
OB_IMBALANCE_MIN_ENTRY=-0.15

# ── Orderbook imbalance position-size boost ───────────────────────────────────
OB_IMBALANCE_BOOST_THRESHOLD=0.50
OB_IMBALANCE_SIZE_MULTIPLIER=2.0

# ── Trade-flow analysis ───────────────────────────────────────────────────────
TRADE_FLOW_MIN_BUY_RATIO=0.45

# ── Momentum exit ─────────────────────────────────────────────────────────────
MOMENTUM_EXIT_OB_THRESHOLD=0.0
MOMENTUM_EXIT_MIN_PROFIT_PCT=0.03

# ── Pump protection (FOMO guard) ──────────────────────────────────────────────
# Skip entry when price rose > PCT within LOOKBACK_SECONDS
PUMP_PROTECTION_PCT=0.05
PUMP_LOOKBACK_SECONDS=60

# ── Spread filter ─────────────────────────────────────────────────────────────
MAX_SPREAD_PCT=0.005

# ── Spread anomaly filter ─────────────────────────────────────────────────────
SPREAD_ANOMALY_MULTIPLIER=3.0

# ── Small-coin protection (koin sepi) ────────────────────────────────────────
MIN_BUY_PRICE_IDR=100
SMALL_COIN_MIN_VOLUME_24H_IDR=1000000
SMALL_COIN_MIN_TRADES_24H=50
SMALL_COIN_MIN_BID_LEVELS=3
SMALL_COIN_MIN_DEPTH_IDR=50000
SMALL_COIN_MAX_SPREAD_PCT=0.05
MAX_TICK_MOVE_PCT=0.08

# ── Smart Entry Engine (SEE) ──────────────────────────────────────────────────
# Three-part quality filter: pre-pump accumulation, whale pressure, fake-breakout guard
SEE_ENABLED=true
SEE_VOLUME_SURGE_RATIO=2.0
SEE_WHALE_PRESSURE_MIN=2.0
SEE_BREAKOUT_VOLUME_MIN=0.7
# Pump sniper: enter early on forming pumps
SEE_PUMP_SNIPER_ENABLED=true
SEE_PUMP_SNIPER_PRICE_RATIO=1.02
SEE_PUMP_SNIPER_VOLUME_RATIO=2.5
SEE_PUMP_SNIPER_SHORT=3
SEE_PUMP_SNIPER_LONG=12
PUMP_SNIPER_SIZE_MULTIPLIER=1.5
PUMP_SNIPER_SIZE_MIN_SCORE=0.70
# Early breakout entry
EARLY_BREAKOUT_PROXIMITY_PCT=0.005
EARLY_BREAKOUT_MIN_VOLUME_RATIO=1.2

# ── AI-based confidence scoring ───────────────────────────────────────────────
AI_SCORING_ENABLED=false
# AI_SCORING_WEIGHT=0.25

# ── Anti-fake-pump detection ──────────────────────────────────────────────────
FAKE_PUMP_REVERSAL_PCT=0.03

# ── Flash dump protection ─────────────────────────────────────────────────────
FLASH_DUMP_PCT=0.05
FLASH_DUMP_LOOKBACK_SECONDS=60

# ── Post-entry dump exit ──────────────────────────────────────────────────────
POST_ENTRY_DUMP_PCT=0.02
POST_ENTRY_DUMP_WINDOW_SECONDS=120

# ── Orderbook absorption detection ────────────────────────────────────────────
ORDERBOOK_ABSORPTION_THRESHOLD=0.30

# ── Rug-pull / dead-coin filter ───────────────────────────────────────────────
RUG_PULL_MAX_DROP_24H_PCT=0.50
RUG_PULL_MIN_VOLUME_IDR=1000000
RUG_PULL_MIN_TRADES_24H=50

# ── Time-based exit (anti-stagnation) ─────────────────────────────────────────
MAX_HOLD_SECONDS=0
MAX_HOLD_PROFIT_PCT=0.01

# ── Adaptive hold time based on 24-h volume ────────────────────────────────────
VOLUME_HIGH_THRESHOLD_IDR=5000000000
MAX_HOLD_SECONDS_VOLUME_HIGH=5400
MAX_HOLD_SECONDS_VOLUME_LOW=1800

# ── Minimum order value ────────────────────────────────────────────────────────
# Default: 100,000 IDR (bot floor above the 10 K IDR exchange minimum)
MIN_ORDER_IDR=100000

# ── Per-pair minimum order auto-detection ─────────────────────────────────────
PAIR_MIN_ORDER_CACHE_ENABLED=true
PAIR_MIN_ORDER_REFRESH_CYCLES=0

# ── Adaptive position sizing ──────────────────────────────────────────────────
# Automatically adjusts risk and max-positions based on current equity tier.
# Set INITIAL_CAPITAL to your real balance; the bot picks the right tier.
ADAPTIVE_SIZING_ENABLED=true
#
# ── Tier thresholds (IDR) ─────────────────────────────────────────────────────
#   equity < ADAPTIVE_TIER1_EQUITY              → Tier 0 (small capital)
#   ADAPTIVE_TIER1_EQUITY ≤ equity < TIER2     → Tier 1 (medium capital)
#   equity ≥ ADAPTIVE_TIER2_EQUITY              → Tier 2 (large capital)
ADAPTIVE_TIER1_EQUITY=2000000     # 2 M IDR boundary
ADAPTIVE_TIER2_EQUITY=10000000    # 10 M IDR boundary
# Risk per trade for each tier (fraction of equity)
ADAPTIVE_TIER0_RISK=0.10          # small  cap: 10% — one 100K order per 1M equity
ADAPTIVE_TIER1_RISK=0.07          # medium cap: 7%
ADAPTIVE_TIER2_RISK=0.03          # large  cap: 3%
# Max concurrent open positions per tier
ADAPTIVE_TIER0_MAX_POS=2
ADAPTIVE_TIER1_MAX_POS=3
ADAPTIVE_TIER2_MAX_POS=5

# ── Confidence-based position sizing ─────────────────────────────────────────
# Derives position size from confidence tier instead of risk/stop-distance formula.
CONFIDENCE_POSITION_SIZING_ENABLED=true
CONFIDENCE_TIER_SKIP=0.40
CONFIDENCE_TIER_LOW=0.50
CONFIDENCE_TIER_MID=0.65
CONFIDENCE_TIER_HIGH=0.80
CONFIDENCE_TIER_LOW_PCT=0.10
CONFIDENCE_TIER_MID_PCT=0.15
CONFIDENCE_TIER_HIGH_PCT=0.20
CONFIDENCE_TIER_MAX_PCT=0.25

# ── Consecutive loss protection ───────────────────────────────────────────────
MAX_CONSECUTIVE_LOSSES=3

# ── Volatility cooldown ───────────────────────────────────────────────────────
VOLATILITY_COOLDOWN_PCT=0.05
VOLATILITY_COOLDOWN_SECONDS=300

# ── Circuit breaker ────────────────────────────────────────────────────────────
CIRCUIT_BREAKER_MAX_ERRORS=5
CIRCUIT_BREAKER_PAUSE_SECONDS=300

# ── Balance validation ─────────────────────────────────────────────────────────
BALANCE_CHECK_ENABLED=true

# ── Stale order cancellation ──────────────────────────────────────────────────
STALE_ORDER_SECONDS=300

# ── Strategy auto-disable ─────────────────────────────────────────────────────
STRATEGY_AUTO_DISABLE_LOSSES=5

# ── Liquidity Sweep Detection ──────────────────────────────────────────────────
LIQUIDITY_SWEEP_ENABLED=true
LIQUIDITY_SWEEP_LOOKBACK=10
LIQUIDITY_SWEEP_MIN_PCT=0.01
LIQUIDITY_SWEEP_REVERSAL_PCT=0.005

# ── Liquidity Trap Detection ───────────────────────────────────────────────────
LIQUIDITY_TRAP_ENABLED=true
LIQUIDITY_TRAP_BREAKOUT_PCT=0.005
LIQUIDITY_TRAP_REVERSAL_PCT=0.008

# ── Liquidity Vacuum Detection ─────────────────────────────────────────────────
LIQUIDITY_VACUUM_MIN_GAP_PCT=0.02
LIQUIDITY_VACUUM_DEPTH_LEVELS=10

# ── Smart Money Footprint ──────────────────────────────────────────────────────
SMART_MONEY_ENABLED=true
SMART_MONEY_VOLUME_FACTOR=3.0
SMART_MONEY_DIVERGENCE_LOOKBACK=5

# ── Volume Acceleration ─────────────────────────────────────────────────────────
VOLUME_ACCEL_ENABLED=true
VOLUME_ACCEL_WINDOW=5
VOLUME_ACCEL_MIN_RATIO=1.5

# ── Micro Trend Detection ──────────────────────────────────────────────────────
MICRO_TREND_ENABLED=true
MICRO_TREND_WINDOW=3

# ── Spread Expansion Detector ─────────────────────────────────────────────────
SPREAD_EXPANSION_ENABLED=true
SPREAD_EXPANSION_MULTIPLIER=2.0
SPREAD_EXPANSION_WINDOW=10

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Market Data Infrastructure                                              ║
# ║  Enables real-time tick storage, orderbook depth analysis, trade-flow,   ║
# ║  market microstructure, liquidity monitoring, volatility, spread,        ║
# ║  regime detection, cross-exchange comparison, anomaly detection.         ║
# ╚══════════════════════════════════════════════════════════════════════════╝
MARKET_DATA_ENABLED=true
MARKET_DATA_DIR=market_data
MARKET_DATA_MAX_TICKS=100000
MARKET_DATA_TICK_WINDOW=60
MARKET_DATA_LARGE_TRADE_IDR=10000000
MARKET_DATA_STALE_SECONDS=120
MARKET_DATA_ANOMALY_PRICE_PCT=0.05
MARKET_DATA_ANOMALY_VOLUME_MULT=5
MARKET_DATA_ANOMALY_SPREAD_MULT=3
MARKET_DATA_ANOMALY_CRASH_PCT=0.10
