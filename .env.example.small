# ═══════════════════════════════════════════════════════════════════════════════
# .env.example.small — Configuration for SMALL CAPITAL (Rp 500.000 – Rp 2.000.000)
# ═══════════════════════════════════════════════════════════════════════════════
# Optimised for modal kecil: conservative risk, single position, higher
# risk-per-trade to ensure orders meet exchange minimums.
#
# Copy this file to .env and fill in your API credentials:
#   cp .env.example.small .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── API Credentials ───────────────────────────────────────────────────────────
INDODAX_KEY=your_api_key_here
INDODAX_SECRET=your_api_secret_here

# ── Capital & Risk ────────────────────────────────────────────────────────────
INITIAL_CAPITAL=500000
RISK_PER_TRADE=0.15
TARGET_PROFIT_PCT=0.10
MAX_LOSS_PCT=0.08
MAX_SLIPPAGE_PCT=0.002
MIN_ORDER_IDR=30000

# ── Trailing Stop & Take Profit ──────────────────────────────────────────────
TRAILING_STOP_PCT=0.025
TRAILING_TP_PCT=0.015
PARTIAL_TP_FRACTION=0.0
PARTIAL_TP2_FRACTION=0.0
PARTIAL_TP3_FRACTION=0.0

# ── Entry / Execution ────────────────────────────────────────────────────────
ENTRY_AGGRESSIVENESS_PCT=0.001
ENTRY_RETRY_AGGRESSIVENESS_PCT=0.002
CHASE_MAX_RETRIES=3
ORDER_TIMEOUT_TO_MARKET=true
STAGED_ENTRY_STEPS=1
STAGED_ENTRY_MIN_EQUITY=0

# ── Strategy Parameters ──────────────────────────────────────────────────────
REALTIME_MODE=false
INTERVAL_SECONDS=300
FAST_WINDOW=12
SLOW_WINDOW=48
MIN_CONFIDENCE=0.55

# ── Filters ───────────────────────────────────────────────────────────────────
BUY_MAX_RSI=80
BUY_MAX_RESISTANCE_PROXIMITY_PCT=0.015
PAIR_COOLDOWN_SECONDS=600
MIN_BUY_PRICE_IDR=100

# ── Small-coin Safety ────────────────────────────────────────────────────────
SMALL_COIN_MIN_VOLUME_24H_IDR=2000000
SMALL_COIN_MIN_TRADES_24H=100
SMALL_COIN_MIN_BID_LEVELS=3
SMALL_COIN_MIN_DEPTH_IDR=100000
SMALL_COIN_MAX_SPREAD_PCT=0.03

# ── Position Management ──────────────────────────────────────────────────────
MULTI_POSITION_ENABLED=false
MULTI_POSITION_MAX=1
MAX_OPEN_POSITIONS=1
TRADE_MODE=continuous
POSITION_CHECK_INTERVAL=60

# ── Order Queue / Rate Limit ─────────────────────────────────────────────────
ORDER_QUEUE_ENABLED=true
ORDER_MIN_INTERVAL=2.0
SCAN_REQUEST_DELAY=0.2

# ── WebSocket ─────────────────────────────────────────────────────────────────
WEBSOCKET_ENABLED=true
WEBSOCKET_URL=wss://ws3.indodax.com/ws/
WS_STALE_THRESHOLD=120

# ── Scanning ──────────────────────────────────────────────────────────────────
PAIRS_PER_CYCLE=10
MIN_VOLUME_IDR=500000
TRADE_COUNT=500
MIN_CANDLES=20

# ── State Persistence ─────────────────────────────────────────────────────────
STATE_PATH=bot_state.json
STATE_BACKUP_INTERVAL=10

# ── Hold Limits ───────────────────────────────────────────────────────────────
VOLUME_HIGH_THRESHOLD_IDR=5000000000
MAX_HOLD_SECONDS_VOLUME_HIGH=3600
MAX_HOLD_SECONDS_VOLUME_LOW=1800

# ── Pair Minimum Cache ────────────────────────────────────────────────────────
PAIR_MIN_ORDER_CACHE_ENABLED=true

# ── Adaptive Sizing (disabled for small capital) ─────────────────────────────
ADAPTIVE_SIZING_ENABLED=false

# ── Grid (disabled for small capital) ────────────────────────────────────────
GRID_ENABLED=false

# ── Misc ──────────────────────────────────────────────────────────────────────
DRY_RUN=true
RUN_ONCE=false
CYCLE_SUMMARY_INTERVAL=10

# ── Notifications (optional) ─────────────────────────────────────────────────
# TELEGRAM_TOKEN=123456789:ABCDEFGhijklmnopqrstuvwxyz
# TELEGRAM_CHAT_ID=987654321
