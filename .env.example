# Indodax API credentials (both required for live trading)
INDODAX_KEY=your_api_key_here
INDODAX_SECRET=your_api_secret_here

# Risk and sizing
# Order size is computed dynamically: RISK_PER_TRADE * INITIAL_CAPITAL / coin_price
RISK_PER_TRADE=0.01
INITIAL_CAPITAL=1000000
TARGET_PROFIT_PCT=0.2
MAX_LOSS_PCT=0.1
MAX_SLIPPAGE_PCT=0.001
# Trailing stop: price trails peak by this fraction (0 = disabled)
TRAILING_STOP_PCT=0.0

# Strategy parameters
REALTIME_MODE=false
# REAL_TIME is a deprecated alias for REALTIME_MODE (both are accepted)
# When REALTIME_MODE=true, INTERVAL_SECONDS defaults to 1s unless overridden below
INTERVAL_SECONDS=300
FAST_WINDOW=12
SLOW_WINDOW=48
MIN_CONFIDENCE=0.52
GRID_ENABLED=false
GRID_LEVELS_PER_SIDE=3
GRID_SPACING_PCT=0.004
# Optional: override per-level amount (defaults to RISK_PER_TRADE * INITIAL_CAPITAL / price when unset)
# GRID_ORDER_SIZE=0.0002

# ── Trade entry filters ───────────────────────────────────────────────────────
# Skip BUY when RSI is at or above this level (overbought guard).
# 0 = disabled.  Default: 85 (blocks entries at RSI ≥ 85, e.g. RSI=100 spikes).
BUY_MAX_RSI=85
# Skip BUY when the current price is within this fraction of the nearest
# resistance level (avoids buying straight into a wall).
# 0 = disabled.  Default: 0.01 (skip when price is within 1% of resistance).
BUY_MAX_RESISTANCE_PROXIMITY_PCT=0.01
# Block a new BUY on the same pair for this many seconds after the previous trade
# on that pair (prevents rapid re-entry churn on the same coin).
# 0 = disabled.  Default: 300 (5-minute cooldown per pair).
PAIR_COOLDOWN_SECONDS=300

# Order queue / rate limit
ORDER_QUEUE_ENABLED=true
ORDER_MIN_INTERVAL=0.25
# Delay (seconds) between per-pair API requests during pair scanning (prevents HTTP 429)
SCAN_REQUEST_DELAY=0.2
# Recent trade ticks fetched per pair when building candles from /api/trades (fallback to OHLC)
TRADE_COUNT=1000
# Minimum candle count required for reliable RSI/MACD/BB indicators (pairs below are skipped in scan)
MIN_CANDLES=20

# Realtime streaming (WebSocket preferred, REST fallback)
WEBSOCKET_ENABLED=true
# Official Indodax market-data WebSocket (Centrifuge protocol)
WEBSOCKET_URL=wss://ws3.indodax.com/ws/
# Seconds without a WS ticker update before the feed is considered stale and REST fallback activates
WS_STALE_THRESHOLD=120
# Max pairs per WebSocket connection for multi-pair feed (default: 100)
# WEBSOCKET_BATCH_SIZE=100
# Raw JSON string sent to the server on connect (leave unset to use the default subscription message)
# WEBSOCKET_SUBSCRIBE_MESSAGE=

# Multi-pair scan optimisation
# Rotate N pairs per cycle (0 = scan all); reduces per-cycle REST load
PAIRS_PER_CYCLE=50
# Minimum 24-h IDR trading volume a pair must have to be analysed (0 = no filter)
MIN_VOLUME_IDR=0

# Execution mode
DRY_RUN=true
# Number of staged entry tranches used when equity is large enough.
STAGED_ENTRY_STEPS=3
# Minimum portfolio cash (IDR) required to use multi-step staged entry.
# When available cash is below this threshold the bot collapses to a single-step
# entry, preventing all tranches from falling below MIN_ORDER_IDR and being skipped.
# Set to 0 to always use STAGED_ENTRY_STEPS regardless of equity size.
STAGED_ENTRY_MIN_EQUITY=1000000
RUN_ONCE=false

# Autonomous 24/7 operation
# Interval (seconds) used when monitoring an open position between exit checks
POSITION_CHECK_INTERVAL=60
# Print a full performance summary every N completed scan cycles (0 disables)
CYCLE_SUMMARY_INTERVAL=10
# Trading mode: "continuous" = run 24/7 rotating pairs; "single" = one buy→sell cycle then stop
TRADE_MODE=continuous

# Maximum number of open positions allowed across all pairs (0 = no limit)
# MAX_OPEN_POSITIONS=3

# Logging
# Optional path to a log file.  When set, all log lines are written to BOTH
# the terminal and this file simultaneously (append mode).
# LOG_FILE=/var/log/indodax-bot/bot.log

# Optional CSV trade journal path — every completed trade is appended as a row.
# Leave unset to disable.
# JOURNAL_PATH=trade_journal.csv

# Telegram notifications (optional — both token AND chat_id must be set)
# Create a bot via @BotFather and get your chat ID from @userinfobot
# TELEGRAM_TOKEN=123456789:ABCDEFGhijklmnopqrstuvwxyz
# TELEGRAM_CHAT_ID=987654321

# Discord webhook notifications (optional)
# Create an Incoming Webhook in Discord Server Settings → Integrations
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Auto-resume state persistence
STATE_PATH=bot_state.json
STATE_BACKUP_INTERVAL=10

# Multi-timeframe analysis (optional — filters noise by requiring alignment across timeframes)
# Comma-separated list of Indodax OHLC timeframes to fetch per pair in addition to the primary.
# Valid values: 1, 15, 30, 60, 240, 1D.  Leave empty to disable (default).
# MTF_TIMEFRAMES=1,15,60

# Risk exposure caps (0 = disabled)
# MAX_EXPOSURE_PER_COIN_PCT=0.3    # max 30% of equity in one coin at a time
# MAX_DAILY_LOSS_PCT=0.05          # stop trading buys when daily loss exceeds 5% of day-open equity

# Dynamic pair selection — auto-refreshes the watchlist with the top-N most liquid pairs
# 0 = disabled (use the initial static pair list from get_pairs() indefinitely)
DYNAMIC_PAIRS_REFRESH_CYCLES=0
DYNAMIC_PAIRS_TOP_N=50

# ── Top Volume watchlist filters ──────────────────────────────────────────────
# Pre-filter pairs before top-N ranking (both default 0 = disabled).
# Minimum 24-h IDR volume a pair must have to enter the dynamic watchlist
# (stricter than MIN_VOLUME_IDR; applied only during dynamic-pair refresh).
# E.g. 300000000 = require ≥ 300 M IDR/day.
# TOP_VOLUME_MIN_VOLUME_IDR=0
# Minimum absolute 24-h price change required to enter the watchlist.
# Excludes stagnant pairs where signals are meaningless.
# E.g. 0.005 = skip pairs with < 0.5% 24-h price change.
# TOP_VOLUME_MIN_PRICE_CHANGE_24H_PCT=0

# Partial take-profit — sell a fraction of the position when price hits TP, let the rest run
# 0 = sell all (disabled by default).  E.g. 0.5 = sell 50% at TP, keep 50%.
# PARTIAL_TP_FRACTION=0.5

# ── Multi-level partial take-profit ───────────────────────────────────────────
# 2nd TP level: sell a fraction at a second price target above the entry.
# PARTIAL_TP2_FRACTION=0.3     # fraction to sell at 2nd TP (0 = disabled)
# PARTIAL_TP2_TARGET_PCT=0.08  # price must rise 8% above buy price to trigger
#
# 3rd TP level: sell a further fraction at a third price target.
# PARTIAL_TP3_FRACTION=0.3     # fraction to sell at 3rd TP (0 = disabled)
# PARTIAL_TP3_TARGET_PCT=0.12  # price must rise 12% above buy price to trigger

# Re-entry logic — prevent immediate re-buys after a sell
# RE_ENTRY_COOLDOWN_SECONDS=300    # wait at least 5 minutes after selling
# RE_ENTRY_DIP_PCT=0.02            # price must dip 2% below last sell price before re-entering

# Adaptive scan interval — reduce sleep time during high-volatility periods
ADAPTIVE_INTERVAL_ENABLED=false
ADAPTIVE_INTERVAL_MIN_SECONDS=30  # minimum sleep between scans when volatile

# Portfolio-wide risk cap (0 = disabled)
# MAX_PORTFOLIO_RISK_PCT=0.5    # max 50% of equity tied up in open positions

# Minimum order-book depth (IDR) — skip thin markets
# MIN_LIQUIDITY_DEPTH_IDR=50000000  # require at least 50M IDR of bid+ask depth

# ── Capital management: principal / profit-buffer compounding ─────────────────
# The bot separates capital into:
#   principal      = INITIAL_CAPITAL (fixed anchor, never eroded)
#   profit_buffer  = accumulated realised profits (compounds into next trades)
#   effective_cap  = principal + profit_buffer (grows as you win)

# Stop new buys when profit buffer drops X% from its all-time peak
# 0 = disabled (default)
# PROFIT_BUFFER_DRAWDOWN_PCT=0.3   # block buys if profits fall 30% from peak

# ── Dynamic take-profit / let profits run ─────────────────────────────────────
# Instead of always closing at TARGET_PROFIT_PCT, the bot can keep the position
# open and trail a floor below the running peak — capturing more upside while
# locking in profits.

# Trailing take-profit: trail this % below the highest price since TP was hit.
# Default: 0.02 (2%).  0 = close exactly at TARGET_PROFIT_PCT (disabled).
TRAILING_TP_PCT=0.02

# Conditional TP: market-condition checks before allowing the TP exit.
# Hold past TP while trend strength is above this threshold (0 = disabled)
# CONDITIONAL_TP_MIN_TREND_STRENGTH=0.4

# Hold past TP while order-book buy-pressure imbalance >= this (0 = disabled)
# Positive = more bids than asks; e.g. 0.1 = at least 10% bid dominance
# CONDITIONAL_TP_MIN_OB_IMBALANCE=0.1

# Close when RSI exceeds this level — overbought / take profit (0 = disabled)
# CONDITIONAL_TP_MAX_RSI=70

# ── Orderbook wall / sell-wall guard ─────────────────────────────────────────
# Skip buy when total ask-side depth (top-20 levels) is this many times larger
# than total bid-side depth.  Prevents entering against a heavy sell wall.
# 0 = disabled (default).  E.g. 5 = skip buy if asks ≥ 5× bids.
# ORDERBOOK_WALL_THRESHOLD=5

# ── Orderbook depth analysis: entry imbalance guard ──────────────────────────
# Hard-skip BUY when the order-book imbalance falls below this threshold
# (i.e. when sellers dominate the book).
# Imbalance = (bid_vol − ask_vol) / (bid_vol + ask_vol), range −1 … +1.
# Seller-dominant = negative imbalance.  Buyer-dominant = positive imbalance.
# 0 = disabled (default).  E.g. -0.15 = skip buy when sellers dominate by ≥ ~15%.
# OB_IMBALANCE_MIN_ENTRY=0

# ── Orderbook imbalance position-size boost ───────────────────────────────────
# Multiply the computed position size by OB_IMBALANCE_SIZE_MULTIPLIER when
# the book imbalance exceeds OB_IMBALANCE_BOOST_THRESHOLD.
# This lets the bot enter with a larger stake when strong buy pressure is detected.
# Imbalance range −1 … +1.  E.g. 0.50 ≈ bid volume is 3× ask volume.
# 0 = disabled (default).
# OB_IMBALANCE_BOOST_THRESHOLD=0
# Factor by which position size is multiplied when threshold is met.
# OB_IMBALANCE_SIZE_MULTIPLIER=2.0

# ── Trade flow analysis: buy/sell ratio entry filter ─────────────────────────
# Skip BUY when fewer than this fraction of recent trades were buyer-initiated
# (market orders hitting the ask).  Range 0–1.
# E.g. 0.45 = skip buy when < 45% of trades are market buys.
# 0 = disabled (default).  Typical value: 0.45 (seller flow dominant → skip).
# TRADE_FLOW_MIN_BUY_RATIO=0

# ── Momentum exit (early exit on weakening momentum) ─────────────────────────
# Exit a profitable position BEFORE reaching TP when market momentum fades.
# Both conditions must be met simultaneously:
#   1. Order-book imbalance drops below MOMENTUM_EXIT_OB_THRESHOLD
#      (seller pressure detected; range −1 … +1).
#   2. Unrealised profit ≥ MOMENTUM_EXIT_MIN_PROFIT_PCT (protects against early loss).
# 0 = disabled (default).
# MOMENTUM_EXIT_OB_THRESHOLD=0       # e.g. 0.0 = exit when book turns seller-dominant
# MOMENTUM_EXIT_MIN_PROFIT_PCT=0.03  # e.g. only exit early when profit ≥ 3%

# ── Volume momentum ───────────────────────────────────────────────────────────
# The bot already uses volume spikes (volume_now > avg_volume_20 * 2) as part
# of its confidence scoring.  Use the OB imbalance boost and trade-flow filter
# above to further validate entry on volume surges.

# ── Pump protection (FOMO guard) ──────────────────────────────────────────────
# Skip entry when the price has risen by more than PUMP_PROTECTION_PCT within
# the last PUMP_LOOKBACK_SECONDS.  Prevents chasing a pump that is likely to
# retrace.  0 = disabled (default).
# PUMP_PROTECTION_PCT=0.05     # skip buy if price rose >5% in the lookback window
# PUMP_LOOKBACK_SECONDS=60     # rolling window in seconds (default 60s)

# ── Spread filter ─────────────────────────────────────────────────────────────
# Skip any trade (buy or sell) when the live bid-ask spread exceeds this
# fraction of the best bid price.  Wide spreads inflate execution cost.
# 0 = disabled (default).  E.g. 0.005 = skip when spread > 0.5%.
# MAX_SPREAD_PCT=0.005

# ── Spread anomaly filter ─────────────────────────────────────────────────────
# Skip buy when the current spread is more than this multiple of the pair's
# historical average spread.  Detects sudden liquidity withdrawal.
# 0 = disabled (default).  E.g. 3.0 = skip when spread is > 3× its average.
# SPREAD_ANOMALY_MULTIPLIER=0

# ── Small-coin protection filters ─────────────────────────────────────────────
# Skip BUY when the coin price is below this IDR amount.
# Prevents entry into very cheap coins where a single tick is a huge % move.
# 0 = disabled (default).  E.g. 10 = skip coins priced below 10 IDR.
# MIN_BUY_PRICE_IDR=0
#
# Skip BUY when the minimum possible price increment (tick) represents more than
# this fraction of the current price.  Derived from the top-2 orderbook bids.
# 0 = disabled (default).  E.g. 0.08 = skip if smallest tick > 8% of price.
# MAX_TICK_MOVE_PCT=0

# ── Smart Entry Engine (SEE) ─────────────────────────────────────────────────
# Three-part entry quality filter:
#   1. Pre-pump detection — spots early volume accumulation before a pump and
#      boosts buy confidence when a volume surge is forming.
#   2. Whale pressure reading — computes net bid/ask whale ratio to determine
#      whether smart money is net-buying or net-selling.
#   3. Fake breakout guard — requires above-average volume to confirm a real
#      resistance breakout; penalises thin-volume breakouts.
#
# When SEE_ENABLED=true, the three signals adjust trade confidence before
# execution.  All other settings are ignored when SEE_ENABLED=false (default).
# SEE_ENABLED=false
#
# Volume surge ratio: (recent candles avg vol / baseline avg vol) must
# exceed this threshold to flag a pre-pump accumulation pattern.
# E.g. 2.0 = flag when last 3 candles carry 2× the historical average volume.
# SEE_VOLUME_SURGE_RATIO=2.0
#
# Minimum net whale pressure ratio (bid_whale_ratio − ask_whale_ratio) that
# qualifies as significant directional smart-money activity.
# Higher values = fewer but stronger signals.
# SEE_WHALE_PRESSURE_MIN=2.0
#
# Minimum (recent candle volume / average volume) ratio required to confirm
# that a resistance breakout is genuine and not a fake-out.
# E.g. 0.7 = at least 70% of average volume must accompany the breakout.
# SEE_BREAKOUT_VOLUME_MIN=0.7

# ── Anti-fake-pump detection ─────────────────────────────────────────────────
# On Indodax, pump-and-dump cycles frequently complete within ≈20 seconds:
# the price spikes sharply and then dumps back before most traders can react.
# This guard detects the two-phase pattern in the rolling price buffer:
#   Phase 1 – spike : in-window peak rose ≥ PUMP_PROTECTION_PCT vs oldest price
#   Phase 2 – dump  : current price has fallen ≥ FAKE_PUMP_REVERSAL_PCT from peak
# When both phases are detected on a buy signal, the order is skipped.
#
# Requires PUMP_PROTECTION_PCT > 0 (shares the same per-pair price buffer).
# 0 = disabled (default).  E.g. 0.03 = skip when price dropped ≥3% from peak.
# FAKE_PUMP_REVERSAL_PCT=0.03

# ── Flash dump protection ─────────────────────────────────────────────────────
# Skip buy when the price has dropped sharply within a short rolling window.
# FLASH_DUMP_PCT=0               # e.g. 0.05 = skip if price dropped ≥ 5% in window
# FLASH_DUMP_LOOKBACK_SECONDS=60 # rolling window for flash dump detection (default 60s)

# ── Orderbook absorption detection ────────────────────────────────────────────
# Detects when large orders in the book are being continuously absorbed (eaten
# through) by aggressive market orders — a sign of strong directional conviction.
# 0 = disabled (default).
# ORDERBOOK_ABSORPTION_THRESHOLD=0

# ── Rug-pull / dead-coin filter ───────────────────────────────────────────────
# Skip BUY signals on pairs that show characteristics of a rug-pull or dead coin.
# All three criteria are checked from the 24-h ticker; all default to 0 (disabled).
#
# Skip pairs where the price dropped ≥ this fraction from its 24-h high.
# RUG_PULL_MAX_DROP_24H_PCT=0    # e.g. 0.50 = skip if dropped ≥ 50% from 24-h high
#
# Skip pairs with 24-h IDR volume below this amount.
# RUG_PULL_MIN_VOLUME_IDR=0      # e.g. 1000000 = require ≥ 1 M IDR/day
#
# Skip pairs with fewer than this many trades in the last 24 hours.
# RUG_PULL_MIN_TRADES_24H=0      # e.g. 50 = require at least 50 trades/day

# ── Time-based exit (anti-stagnation) ─────────────────────────────────────────
# Force-sell a position that has been open longer than this many seconds without
# reaching the profit threshold.  Prevents capital being locked in slow movers.
# MAX_HOLD_SECONDS=0             # e.g. 1800 = force-sell after 30 min (0 = disabled)
# MAX_HOLD_PROFIT_PCT=0.01       # only force-sell when profit < this (default 1%)

# ── Indodax minimum order value ──────────────────────────────────────────────
# Indodax requires every order to have a total IDR value (price × amount) of at
# least 10,000 IDR.  Orders that fall below this threshold are rejected by the
# exchange with "Minimum order 10,000 IDR".  The bot checks this limit before
# submitting so the outcome is a graceful "skipped" log rather than a crash.
# Raise this value if you want to avoid very small trades (e.g. 50000 = 50K IDR).
# Must be positive.  Default: 15000 (slightly above Indodax exchange minimum).
# MIN_ORDER_IDR=15000

# ── Per-pair minimum order auto-detection ─────────────────────────────────────
# Fetch the exchange pair list on startup and cache per-pair minimum trade
# amounts (coin and IDR).  The cache is consulted before every order so tiny
# amounts never reach the exchange.  Enabled by default.
PAIR_MIN_ORDER_CACHE_ENABLED=true
# How often (in scan cycles) to re-fetch and refresh the pair minimum cache.
# 0 = fetch once on startup, never refresh (default).
# PAIR_MIN_ORDER_REFRESH_CYCLES=0

# ── Adaptive position sizing ──────────────────────────────────────────────────
# When enabled, RISK_PER_TRADE and max open positions are automatically scaled
# based on current equity (principal + realised profits), making the bot more
# aggressive with small capital and conservative with large capital.
#
# Three equity tiers (IDR):
#   equity < ADAPTIVE_TIER1_EQUITY              → Tier 0 (small)
#   ADAPTIVE_TIER1_EQUITY ≤ equity < ADAPTIVE_TIER2_EQUITY → Tier 1 (medium)
#   equity ≥ ADAPTIVE_TIER2_EQUITY              → Tier 2 (large)
#
# false = use static RISK_PER_TRADE / MAX_OPEN_POSITIONS (default).
ADAPTIVE_SIZING_ENABLED=false
# Equity thresholds (IDR)
ADAPTIVE_TIER1_EQUITY=2000000   # below this → Tier 0
ADAPTIVE_TIER2_EQUITY=5000000   # above this → Tier 2
# Risk per trade for each tier (fraction of equity, e.g. 0.10 = 10%)
ADAPTIVE_TIER0_RISK=0.10        # small cap: 10%
ADAPTIVE_TIER1_RISK=0.07        # medium cap: 7%
ADAPTIVE_TIER2_RISK=0.03        # large cap: 3%
# Maximum open positions per tier
ADAPTIVE_TIER0_MAX_POS=3
ADAPTIVE_TIER1_MAX_POS=4
ADAPTIVE_TIER2_MAX_POS=5

# ── Confidence-based position sizing ─────────────────────────────────────────
# When enabled, position size is derived directly from the confidence tier
# rather than from the risk/stop-distance formula.  The four tiers below map
# a confidence range to a fixed percentage of available capital.
#
# false = use standard risk-based sizing (default).
# CONFIDENCE_POSITION_SIZING_ENABLED=false
#
# Confidence thresholds and matching capital allocation:
#   confidence < CONFIDENCE_TIER_SKIP              → skip trade
#   CONFIDENCE_TIER_SKIP  ≤ conf < CONFIDENCE_TIER_LOW  → CONFIDENCE_TIER_LOW_PCT  of capital
#   CONFIDENCE_TIER_LOW   ≤ conf < CONFIDENCE_TIER_MID  → CONFIDENCE_TIER_MID_PCT  of capital
#   CONFIDENCE_TIER_MID   ≤ conf < CONFIDENCE_TIER_HIGH → CONFIDENCE_TIER_HIGH_PCT of capital
#   conf ≥ CONFIDENCE_TIER_HIGH                    → CONFIDENCE_TIER_MAX_PCT  of capital
#
# CONFIDENCE_TIER_SKIP=0.40     # below 40% confidence: skip
# CONFIDENCE_TIER_LOW=0.50      # 40–50% → low allocation
# CONFIDENCE_TIER_MID=0.65      # 50–65% → mid allocation
# CONFIDENCE_TIER_HIGH=0.80     # 65–80% → high allocation
# CONFIDENCE_TIER_LOW_PCT=0.10  # 10% of capital
# CONFIDENCE_TIER_MID_PCT=0.15  # 15% of capital
# CONFIDENCE_TIER_HIGH_PCT=0.20 # 20% of capital
# CONFIDENCE_TIER_MAX_PCT=0.25  # 25% of capital (≥ CONFIDENCE_TIER_HIGH)

# ── Consecutive loss protection ───────────────────────────────────────────────
# Stop placing new buy orders after N consecutive losing sells in a row.
# 0 = disabled (default).  E.g. 3 = pause buying after 3 losses in a row.
# MAX_CONSECUTIVE_LOSSES=0

# ── Volatility cooldown ───────────────────────────────────────────────────────
# Temporarily pause buying when a pair's price spikes by VOLATILITY_COOLDOWN_PCT
# within a single scan cycle.  VOLATILITY_COOLDOWN_SECONDS sets the pause duration.
# 0 = disabled (default).
# VOLATILITY_COOLDOWN_PCT=0.05     # e.g. skip pair if price moved ≥ 5% this cycle
# VOLATILITY_COOLDOWN_SECONDS=300  # pause for 5 minutes after a spike

# ── Circuit breaker ────────────────────────────────────────────────────────────
# Pause all trading for CIRCUIT_BREAKER_PAUSE_SECONDS after
# CIRCUIT_BREAKER_MAX_ERRORS consecutive API errors.
# 0 = disabled (default).
# CIRCUIT_BREAKER_MAX_ERRORS=5
# CIRCUIT_BREAKER_PAUSE_SECONDS=300

# ── Balance validation ─────────────────────────────────────────────────────────
# When enabled, the bot verifies the actual exchange balance before placing a
# sell order.  Catches cases where the tracked position drifts from reality
# (e.g. manual trades, partial fills, exchange glitches).
# false = disabled (default).
# BALANCE_CHECK_ENABLED=false

# ── Stale order cancellation ──────────────────────────────────────────────────
# Cancel open limit orders that have not been filled after this many seconds.
# 0 = disabled (default).  E.g. 300 = cancel after 5 minutes.
# STALE_ORDER_SECONDS=0

# ── Strategy auto-disable ─────────────────────────────────────────────────────
# Automatically disable a strategy (skip its signals) after it produces N
# consecutive losing trades.  0 = disabled (default).
# STRATEGY_AUTO_DISABLE_LOSSES=0

