# ═══════════════════════════════════════════════════════════════════════════════
# .env.example.large — Configuration for LARGE CAPITAL (Rp 10.000.000+)
# ═══════════════════════════════════════════════════════════════════════════════
# Professional setup: multi-position (up to 5), staged entries (3 steps),
# all partial take-profit tiers enabled, adaptive sizing, grid support,
# aggressive safety filters, and full risk management.
#
# Copy this file to .env and fill in your API credentials:
#   cp .env.example.large .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── API Credentials ───────────────────────────────────────────────────────────
INDODAX_KEY=your_api_key_here
INDODAX_SECRET=your_api_secret_here

# ── Capital & Risk ────────────────────────────────────────────────────────────
INITIAL_CAPITAL=20000000
RISK_PER_TRADE=0.02
TARGET_PROFIT_PCT=0.20
MAX_LOSS_PCT=0.10
MAX_SLIPPAGE_PCT=0.001
MIN_ORDER_IDR=30000

# ── Trailing Stop & Take Profit ──────────────────────────────────────────────
TRAILING_STOP_PCT=0.03
TRAILING_TP_PCT=0.02
PARTIAL_TP_FRACTION=0.4
PARTIAL_TP2_FRACTION=0.3
PARTIAL_TP2_TARGET_PCT=0.08
PARTIAL_TP3_FRACTION=0.3
PARTIAL_TP3_TARGET_PCT=0.12

# ── Entry / Execution ────────────────────────────────────────────────────────
ENTRY_AGGRESSIVENESS_PCT=0.0005
ENTRY_RETRY_AGGRESSIVENESS_PCT=0.001
CHASE_MAX_RETRIES=3
ORDER_TIMEOUT_TO_MARKET=true
STAGED_ENTRY_STEPS=3
STAGED_ENTRY_MIN_EQUITY=5000000

# ── Strategy Parameters ──────────────────────────────────────────────────────
REALTIME_MODE=false
INTERVAL_SECONDS=300
FAST_WINDOW=12
SLOW_WINDOW=48
MIN_CONFIDENCE=0.52

# ── Filters ───────────────────────────────────────────────────────────────────
BUY_MAX_RSI=85
BUY_MAX_RESISTANCE_PROXIMITY_PCT=0.01
PAIR_COOLDOWN_SECONDS=300
MIN_BUY_PRICE_IDR=100

# ── Small-coin Safety ────────────────────────────────────────────────────────
SMALL_COIN_MIN_VOLUME_24H_IDR=1000000
SMALL_COIN_MIN_TRADES_24H=50
SMALL_COIN_MIN_BID_LEVELS=3
SMALL_COIN_MIN_DEPTH_IDR=50000
SMALL_COIN_MAX_SPREAD_PCT=0.05

# ── Position Management ──────────────────────────────────────────────────────
MULTI_POSITION_ENABLED=true
MULTI_POSITION_MAX=5
MAX_OPEN_POSITIONS=5
TRADE_MODE=continuous
POSITION_CHECK_INTERVAL=60

# ── Order Queue / Rate Limit ─────────────────────────────────────────────────
ORDER_QUEUE_ENABLED=true
ORDER_MIN_INTERVAL=2.0
SCAN_REQUEST_DELAY=0.2
ACCOUNT_INFO_CACHE_TTL=30
OPEN_ORDERS_CACHE_TTL=15

# ── WebSocket ─────────────────────────────────────────────────────────────────
WEBSOCKET_ENABLED=true
WEBSOCKET_URL=wss://ws3.indodax.com/ws/
WS_STALE_THRESHOLD=120

# ── Scanning ──────────────────────────────────────────────────────────────────
PAIRS_PER_CYCLE=30
MIN_VOLUME_IDR=0
TRADE_COUNT=1000
MIN_CANDLES=20

# ── State Persistence ─────────────────────────────────────────────────────────
STATE_PATH=bot_state.json
STATE_BACKUP_INTERVAL=10

# ── Dynamic Pair Discovery ───────────────────────────────────────────────────
DYNAMIC_PAIRS_REFRESH_CYCLES=0
DYNAMIC_PAIRS_TOP_N=50

# ── Hold Limits ───────────────────────────────────────────────────────────────
VOLUME_HIGH_THRESHOLD_IDR=5000000000
MAX_HOLD_SECONDS_VOLUME_HIGH=5400
MAX_HOLD_SECONDS_VOLUME_LOW=1800

# ── Pair Minimum Cache ────────────────────────────────────────────────────────
PAIR_MIN_ORDER_CACHE_ENABLED=true

# ── Adaptive Sizing ──────────────────────────────────────────────────────────
ADAPTIVE_SIZING_ENABLED=true
ADAPTIVE_TIER1_EQUITY=5000000
ADAPTIVE_TIER2_EQUITY=15000000
ADAPTIVE_TIER0_RISK=0.08
ADAPTIVE_TIER1_RISK=0.05
ADAPTIVE_TIER2_RISK=0.02
ADAPTIVE_TIER0_MAX_POS=3
ADAPTIVE_TIER1_MAX_POS=4
ADAPTIVE_TIER2_MAX_POS=5

# ── Adaptive Interval ────────────────────────────────────────────────────────
ADAPTIVE_INTERVAL_ENABLED=true
ADAPTIVE_INTERVAL_MIN_SECONDS=30

# ── Grid Trading (optional — enable for ranging markets) ─────────────────────
GRID_ENABLED=false
GRID_LEVELS_PER_SIDE=3
GRID_SPACING_PCT=0.004

# ── Momentum Exit ────────────────────────────────────────────────────────────
MOMENTUM_EXIT_OB_THRESHOLD=0
MOMENTUM_EXIT_MIN_PROFIT_PCT=0.03

# ── Post-entry Dump Protection ───────────────────────────────────────────────
POST_ENTRY_DUMP_PCT=0.03
POST_ENTRY_DUMP_WINDOW_SECONDS=120

# ── Daily Loss Cap ───────────────────────────────────────────────────────────
MAX_DAILY_LOSS_PCT=0.05

# ── Profit Buffer Drawdown Guard ─────────────────────────────────────────────
PROFIT_BUFFER_DRAWDOWN_PCT=0.3

# ── Misc ──────────────────────────────────────────────────────────────────────
DRY_RUN=true
RUN_ONCE=false
CYCLE_SUMMARY_INTERVAL=10

# ── Notifications (recommended for large capital) ────────────────────────────
# TELEGRAM_TOKEN=123456789:ABCDEFGhijklmnopqrstuvwxyz
# TELEGRAM_CHAT_ID=987654321
